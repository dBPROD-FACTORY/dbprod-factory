---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map(p => ({ params: { id: p.data.id }, props: { post: p } }));
}
const { post } = Astro.props;
const d = post.data;
const { Content } = await post.render();

const allPosts = await getCollection("posts");
const related = allPosts
  .filter(p => p.data.id !== d.id && p.data.tag === d.tag)
  .slice(0, 3);
const fallback = allPosts
  .filter(p => p.data.id !== d.id && !related.find(r => r.data.id === p.data.id))
  .slice(0, 3 - related.length);
const similarPosts = [...related, ...fallback].slice(0, 3);
---
<Base title={d.title}>
  <article>
    <!-- Header -->
    <header style="padding: 140px 0 0;">
      <div class="container-narrow">
        <a href="/blog" style="display:inline-flex;align-items:center;gap:8px;color:var(--fg-dim);text-decoration:none;font-size:13px;font-family:var(--f-mono);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:40px;transition:color 0.2s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-dim)'">
          ← Journal
        </a>

        <div style="display:flex;gap:10px;align-items:center;margin-bottom:24px;flex-wrap:wrap;">
          <span class="chip chip-accent">{d.tag}</span>
          <span class="mono">{d.date}</span>
          <span class="mono" style="color:var(--fg-mute);">· {d.read} de lecture</span>
        </div>

        <h1 class="h-display" style="font-size:clamp(40px,6vw,88px);margin:0 0 28px;line-height:0.96;">
          {d.title}
        </h1>

        <p style="font-size:19px;color:var(--fg-dim);line-height:1.6;max-width:680px;margin:0 0 48px;">
          {d.excerpt}
        </p>
      </div>
    </header>

    <!-- Cover image -->
    <div style="width:100%;margin-bottom:64px;overflow:hidden;">
      <div class="container-narrow">
        <div
          class="media-ph"
          data-label={d.tag?.toUpperCase()}
          style={`border-radius:var(--radius-lg);overflow:hidden;aspect-ratio:21/9;${d.cover ? '' : ''}`}
        >
          {d.cover && (
            <img src={d.cover} alt={d.title} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
          )}
          <div style={`position:absolute;inset:0;background:${d.cover ? 'linear-gradient(to top,color-mix(in oklab,var(--bg) 20%,transparent),transparent)' : 'linear-gradient(135deg,color-mix(in oklab,var(--accent) 15%,transparent),transparent 65%)'};`} />
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="container-narrow">
      <div class="prose">
        <Content />
      </div>

      <!-- Share / back -->
      <div style="margin-top:72px;padding-top:40px;border-top:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
        <a href="/blog" style="display:inline-flex;align-items:center;gap:8px;color:var(--fg-dim);text-decoration:none;font-size:13px;font-family:var(--f-mono);text-transform:uppercase;letter-spacing:0.08em;transition:color 0.2s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-dim)'">
          ← Retour au journal
        </a>
        <a href="/contact" class="btn btn-primary btn-arrow">Demander un devis</a>
      </div>
    </div>

    <!-- Related articles -->
    {similarPosts.length > 0 && (
      <section style="padding:80px 0 100px;margin-top:80px;border-top:1px solid var(--line);">
        <div class="container">
          <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:40px;">
            <h2 class="h-display" style="font-size:clamp(32px,4vw,56px);margin:0;">Articles similaires</h2>
            <a href="/blog" style="color:var(--fg-dim);text-decoration:none;font-size:13px;font-family:var(--f-mono);text-transform:uppercase;letter-spacing:0.08em;">Tout voir →</a>
          </div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;" class="grid-responsive-3">
            {similarPosts.map(p => (
              <a
                href={`/blog/${p.data.id}`}
                style="display:flex;flex-direction:column;text-decoration:none;color:var(--fg);border-radius:var(--radius);overflow:hidden;border:1px solid var(--line);background:var(--bg-elev);transition:border-color 0.3s var(--ease),transform 0.3s var(--ease);"
                onmouseover="this.style.borderColor='var(--line-2)';this.style.transform='translateY(-2px)'"
                onmouseout="this.style.borderColor='var(--line)';this.style.transform='none'"
              >
                <div
                  class="media-ph"
                  data-label={p.data.tag?.toUpperCase()}
                  style="aspect-ratio:16/9;flex-shrink:0;position:relative;overflow:hidden;"
                >
                  {p.data.cover && (
                    <img src={p.data.cover} alt={p.data.title} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
                  )}
                  <div style={`position:absolute;inset:0;background:linear-gradient(135deg,color-mix(in oklab,var(--accent) 10%,transparent),transparent 70%);`} />
                </div>
                <div style="padding:20px 24px 24px;display:flex;flex-direction:column;gap:10px;flex:1;">
                  <span class="chip chip-accent" style="align-self:flex-start;">{p.data.tag}</span>
                  <h3 class="h-serif" style="font-size:18px;margin:0;line-height:1.25;">{p.data.title}</h3>
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-top:auto;padding-top:14px;border-top:1px solid var(--line);">
                    <span class="mono" style="font-size:10px;">{p.data.date}</span>
                    <span style="font-size:12px;color:var(--accent);font-weight:500;">Lire →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</Base>

<style>
.prose {
  font-size: 18px;
  line-height: 1.75;
  color: var(--fg);
  max-width: 720px;
}

.prose h2 {
  font-family: var(--f-display);
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 300;
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin: 2.5em 0 0.8em;
  color: var(--fg);
}

.prose h3 {
  font-family: var(--f-display);
  font-size: clamp(20px, 2.2vw, 26px);
  font-weight: 400;
  letter-spacing: -0.02em;
  margin: 2em 0 0.7em;
  color: var(--fg);
}

.prose h4 {
  font-size: 16px;
  font-weight: 600;
  margin: 1.8em 0 0.5em;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--fg-dim);
}

.prose p {
  margin: 0 0 1.4em;
}

.prose p:first-child {
  font-size: 20px;
  color: var(--fg-dim);
}

.prose a {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
}

.prose strong {
  color: var(--fg);
  font-weight: 600;
}

.prose em {
  font-style: italic;
  color: var(--fg-dim);
}

.prose ul,
.prose ol {
  padding-left: 1.5em;
  margin: 0 0 1.4em;
}

.prose li {
  margin-bottom: 0.5em;
}

.prose li::marker {
  color: var(--accent);
}

.prose blockquote {
  margin: 2em 0;
  padding: 20px 28px;
  border-left: 3px solid var(--accent);
  background: color-mix(in oklab, var(--accent) 6%, var(--bg-elev));
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 19px;
  font-style: italic;
  color: var(--fg-dim);
}

.prose blockquote p {
  margin: 0;
  font-size: inherit;
  color: inherit;
}

.prose code {
  font-family: var(--f-mono);
  font-size: 0.85em;
  background: var(--bg-elev-2);
  padding: 2px 6px;
  border-radius: 4px;
  color: var(--accent);
}

.prose pre {
  background: var(--bg-elev-2);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  padding: 20px 24px;
  overflow-x: auto;
  margin: 1.5em 0;
}

.prose pre code {
  background: transparent;
  padding: 0;
  color: var(--fg);
  font-size: 14px;
}

.prose hr {
  border: 0;
  height: 1px;
  background: var(--line);
  margin: 2.5em 0;
}

.prose img {
  width: 100%;
  border-radius: var(--radius);
  margin: 1.5em 0;
}

.prose table {
  width: 100%;
  border-collapse: collapse;
  font-size: 15px;
  margin: 1.5em 0;
}

.prose th {
  text-align: left;
  font-family: var(--f-mono);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--fg-dim);
  padding: 10px 16px;
  border-bottom: 1px solid var(--line-2);
}

.prose td {
  padding: 12px 16px;
  border-bottom: 1px solid var(--line);
  color: var(--fg-dim);
}

.prose tr:last-child td { border-bottom: 0; }
</style>
