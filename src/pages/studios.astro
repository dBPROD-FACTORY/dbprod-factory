---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import Icon from "../components/Icon.jsx";
const studios = (await getCollection("studios")).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---
<Base title="Studios">
  <section style="padding:160px 0 80px;">
    <div class="container">
      <div class="eyebrow" style="margin-bottom:28px;">Studios</div>
      <h1 class="h-display" style="font-size:clamp(64px,10vw,160px);margin:0 0 40px;">
        4 <em style="font-style:italic;color:var(--accent);">studios</em>.<br/>Une acoustique sur-mesure.
      </h1>
      <div style="display:grid;gap:20px;margin-top:80px;">
        {studios.map(s => (
          <div class="card" style="padding:40px;display:grid;grid-template-columns:80px 2fr 3fr auto;gap:32px;align-items:center;">
            <div style="width:72px;height:72px;border-radius:16px;background:var(--accent);color:#0A0A0F;display:grid;place-items:center;font-family:var(--f-mono);font-weight:700;font-size:32px;">{s.data.id}</div>
            <div>
              <h3 class="h-serif" style="font-size:26px;margin:0 0 8px;">{s.data.name}</h3>
              <p class="text-dim" style="font-size:14px;margin:0;">{s.data.spec}</p>
            </div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              {s.data.equip.map(e => <span class="chip">{e}</span>)}
            </div>
            <div style="text-align:right;">
              <div class="mono" style="font-size:10px;">Surface</div>
              <div class="h-serif" style="font-size:20px;">{s.data.surface}</div>
              <div class="mono" style="font-size:10px;margin-top:8px;">RT60</div>
              <div class="h-serif" style="font-size:20px;">{s.data.rt60}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
