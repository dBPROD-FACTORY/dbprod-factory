---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import Icon from "../../components/Icon.jsx";
const services = (await getCollection("services")).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---
<Base title="Services">
  <section style="padding:160px 0 80px;">
    <div class="container">
      <div class="eyebrow" style="margin-bottom:28px;">Services</div>
      <h1 class="h-display" style="font-size:clamp(64px,10vw,160px);margin:0 0 60px;">
        12 <em style="font-style:italic;color:var(--accent);">disciplines</em>.<br/>Une vision.
      </h1>
      <p class="text-dim" style="font-size:18px;max-width:680px;margin-bottom:80px;">
        De la prise de voix à la livraison broadcast — chaque discipline est traitée par des spécialistes natifs, avec un contrôle qualité intégral.
      </p>
    </div>
    <div class="container">
      <div style="border:1px solid var(--line);border-radius:24px;overflow:hidden;background:var(--bg-elev);">
        {services.map((s, i) => (
          <a href={`/services/${s.data.id}`} style={`display:grid;grid-template-columns:80px 1fr 2fr 1fr auto;gap:24px;align-items:center;padding:28px 32px;border-top:${i === 0 ? "none" : "1px solid var(--line)"};color:var(--fg);text-decoration:none;`}>
            <span class="mono" style="font-size:12px;">{s.data.num}</span>
            <div style="display:flex;align-items:center;gap:16px;">
              <div style="width:44px;height:44px;border-radius:10px;border:1px solid var(--line-2);display:grid;place-items:center;color:var(--accent);">
                <Icon name={s.data.icon} size={20} stroke={1.5} />
              </div>
              <span class="h-serif" style="font-size:28px;">{s.data.title}</span>
            </div>
            <span class="text-dim" style="font-size:14px;">{s.data.short}</span>
            <div>{s.data.tag && <span class="chip chip-accent">{s.data.tag}</span>}</div>
            <Icon name="arrowUpRight" size={20} stroke={1.5} />
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
