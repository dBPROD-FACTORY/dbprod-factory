---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import VoicesList from "../components/VoicesList.jsx";
const voices = (await getCollection("voices")).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const voicesData = voices.map(v => v.data);
---
<Base title="Banque de voix">
  <section style="padding:160px 0 80px;">
    <div class="container">
      <div class="eyebrow" style="margin-bottom:28px;">Casting · Banque de voix</div>
      <h1 class="h-display" style="font-size:clamp(64px,11vw,180px);margin:0 0 40px;">
        150+ <em style="font-style:italic;color:var(--accent);">voix</em> castées.
      </h1>
      <p class="text-dim" style="font-size:18px;max-width:680px;margin-bottom:80px;">
        Écoute directe de nos comédiens. Filtre par langue, genre ou registre. Casting sur mesure disponible sur demande.
      </p>
      <VoicesList client:load voices={voicesData} />
    </div>
  </section>
</Base>
