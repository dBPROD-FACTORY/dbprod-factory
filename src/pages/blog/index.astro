---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import BlogList from "../../components/BlogList.jsx";
const posts = (await getCollection("posts")).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const postsData = posts.map(p => p.data);
const featured = postsData.find(p => p.featured)?.id;
---
<Base title="Journal">
  <section style="padding:160px 0 80px;">
    <div class="container">
      <div class="grid-responsive-2" style="display:grid;grid-template-columns:1fr 1fr;gap:60px;margin-bottom:80px;align-items:flex-end;">
        <div>
          <div class="eyebrow" style="margin-bottom:28px;">Journal · Ressources</div>
          <h1 class="h-display" style="font-size:clamp(72px,12vw,180px);margin:0;line-height:0.9;">
            Le <em style="font-style:italic;color:var(--accent);">journal</em>
          </h1>
        </div>
        <p class="text-dim" style="font-size:16px;max-width:440px;">
          Techniques, coulisses, opinions. Nos réflexions sur le doublage, la post-production et les métiers de la voix.
        </p>
      </div>
      <BlogList client:load posts={postsData} featuredId={featured} />
    </div>
  </section>
</Base>
